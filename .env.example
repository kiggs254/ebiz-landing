# Base URL of the E-biz Manager portal that backs the contact + onboarding
# forms (stores leads, sends email, runs the AI onboarding assist).
# Local dev: point at your local Manager (default dev port 4100).
NEXT_PUBLIC_MANAGER_API=https://manager.e-biz.co.ke

# Optional: Google Search Console verification token.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
